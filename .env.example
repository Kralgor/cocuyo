# === Phase 1 (required from day one) ===

# Pipeline phase (integer 1-5, controls runtime behavior)
COCUYO_PHASE=1

# Supabase — pipeline uses service_role for reads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — pipeline uploads status.json here
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Frontend (public, embedded in client-side bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STATUS_URL=https://cdn.cocuyo.app/status.json

# === Phase 2 (passive internet monitoring) ===

# Cloudflare Radar (free token from dash.cloudflare.com)
# CF_API_TOKEN=

# === Phase 3 (satellite + weather) ===

# NASA Earthdata (free account at urs.earthdata.nasa.gov)
# NASA_TOKEN=